# ── Google Cloud TTS credentials ────────────────────────────────────────────
#
# Option A (recommended for CI/CD): paste the entire service-account JSON
# as a single-line string (escape inner quotes or use base64 if needed).
GCLOUD_TTS_KEY_JSON=

# Option B (local dev): path to a downloaded service-account JSON key file.
# The Google Cloud SDK also honours this variable automatically.
GOOGLE_APPLICATION_CREDENTIALS=./my-project-credentials.json
